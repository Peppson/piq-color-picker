<Window
    x:Class="ColorPicker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="clr-namespace:ColorPicker.Components"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ColorPicker"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Color Grab"
    Width="450"
    Height="250"
    MinWidth="440"
    MinHeight="240"
    AllowsTransparency="True"
    Background="{StaticResource WindowBorder}"
    FontFamily="Consolas"
    Icon="pack://application:,,,/Assets/FullSizeIcon_32.ico"
    ResizeMode="CanResizeWithGrip"
    WindowState="Normal"
    WindowStyle="None"
    mc:Ignorable="d">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" ResizeBorderThickness="{x:Static SystemParameters.WindowResizeBorderThickness}" />
    </WindowChrome.WindowChrome>

    <Border Style="{StaticResource WindowBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Title Bar  -->
            <components:WindowTitleBar x:Name="TopTitleBar" Grid.Row="0" />

            <!--  App  -->
            <components:ColorPicker
                x:Name="ColorPicker"
                Grid.Row="1"
                Visibility="Visible" />

            <!--  Settings  -->
            <ContentPresenter x:Name="Settings" Grid.Row="1" />
        </Grid>
    </Border>
</Window>
